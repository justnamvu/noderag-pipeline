# App
APP_NAME=NodeAG
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Vector DB
VECTOR_DB_URL=

# Embeddings 
EMBEDDING_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

#LLM
LLM_API_KEY=
LLM_MODEL_NAME=gpt-5.4-nano

MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,txt,docx

# Running inside Docker Compose (service-to-service)
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_NAME=noderag_vectors